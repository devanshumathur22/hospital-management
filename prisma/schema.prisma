generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  doctor
  patient
  receptionist
  nurse
}

enum AppointmentStatus {
  pending
  ready
  confirmed
  cancelled
  completed
}

enum QueueStatus {
  waiting
  in_consultation
  completed
}

enum Day {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

//////////////////////////////
// ADMIN
//////////////////////////////

model Admin {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  userId String? @db.ObjectId

  user User? @relation("UserAdmins", fields: [userId], references: [id])

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////
// DOCTOR
//////////////////////////////

model Doctor {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  userId String? @db.ObjectId

  user User? @relation("UserDoctors", fields: [userId], references: [id])

  name String

  specialization String
  experience     Int

  degree String?
  phone  String?
  image  String?
  about  String?

  rating       Float @default(0)
  totalReviews Int   @default(0)

  nurses Nurse[] @relation("DoctorNurses")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments  Appointment[]
  prescriptions Prescription[]
  schedules     Schedule[]
  slots         Slot[]
  queues        Queue[]
  admissions    Admission[]
  vitals        Vital[]

  availability Json? // ✅ THIS IS CORRECT

  @@index([specialization])
}

//////////////////////////////
// PATIENT
//////////////////////////////

model Patient {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  userId String? @db.ObjectId

  user User? @relation("UserPatients", fields: [userId], references: [id])

  name String

  mrn String?

  phone  String?
  gender String?
  dob    DateTime?

  address String?

  bloodGroup       String?
  emergencyContact String?

  allergies      String?
  medicalHistory String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments  Appointment[]
  prescriptions Prescription[]
  queues        Queue[]
  vitals        Vital[]
  pharmacyBills PharmacyBill[]
  bills         Bill[]
  admissions    Admission[]

  @@index([phone])
}

//////////////////////////////
// APPOINTMENTS
//////////////////////////////

model Appointment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  doctorId  String @db.ObjectId
  patientId String @db.ObjectId

  date DateTime
  time String

  token  Int               @default(1)
  status AppointmentStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor  Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [patientId], references: [id], onDelete: NoAction)

  prescription Prescription[]

  // 🔥 ADD THIS
  bills Bill[]

  @@unique([doctorId, date, time])
  @@index([doctorId])
  @@index([patientId])
}

//////////////////////////////
// PRESCRIPTIONS
//////////////////////////////

model Prescription {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  doctorId      String @db.ObjectId // ❗ required
  patientId     String @db.ObjectId
  appointmentId String @unique @db.ObjectId // ❗ required + unique

  medicine Json
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([patientId])
}

//////////////////////////////
// DOCTOR SCHEDULE
//////////////////////////////

model Schedule {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  doctorId String @db.ObjectId
  day      Day

  startTime String
  endTime   String

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, day])
  @@index([doctorId])
}

//////////////////////////////
// APPOINTMENT SLOTS
//////////////////////////////

model Slot {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  doctorId String   @db.ObjectId
  date     DateTime
  time     String

  isBooked Boolean @default(false)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date, time])
  @@index([doctorId])
}

//////////////////////////////
// RECEPTIONIST
//////////////////////////////

model Receptionist {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  userId String? @db.ObjectId

  user User? @relation("UserReceptionists", fields: [userId], references: [id])

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////
// NURSE
//////////////////////////////

model Nurse {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // 🔐 USER RELATION
  userId String? @db.ObjectId
  user   User?   @relation("UserNurses", fields: [userId], references: [id])

  // BASIC INFO
  name  String
  phone String?
  image String?

  // 👨‍⚕️ DOCTOR ASSIGNMENT
  doctorId String? @db.ObjectId
  doctor   Doctor? @relation("DoctorNurses", fields: [doctorId], references: [id])

  // 📊 RELATIONS
  vitals     Vital[]
  admissions Admission[] // 🔥 ADD

  // ⚡ STATUS
  status String @default("active")

  // ⏱️ TIMESTAMPS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🔍 INDEXES
  @@index([doctorId])
  @@index([userId])
}

//////////////////////////////
// PATIENT VITALS
//////////////////////////////

model Vital {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  patientId String @db.ObjectId
  nurseId   String @db.ObjectId
  doctorId  String @db.ObjectId // 🔥 ADD THIS

  bp          String?
  temperature Float?
  pulse       Int?

  notes String?

  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nurse   Nurse   @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade) // 🔥 ADD

  @@index([patientId])
  @@index([doctorId]) // 🔥 ADD
}

//////////////////////////////
// QUEUE
//////////////////////////////

model Queue {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  token Int

  doctorId  String @db.ObjectId
  patientId String @db.ObjectId

  status QueueStatus @default(waiting)

  createdAt DateTime @default(now())

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([doctorId, token])
  @@index([doctorId])
  @@index([patientId])
}

//////////////////////////////
//pharmacyBills
/////////////////////////////
model PharmacyBill {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  patientId String  @db.ObjectId
  patient   Patient @relation(fields: [patientId], references: [id])

  total Float

  items PharmacyBillItem[] // 🔥 relation

  createdAt DateTime @default(now())
}

model PharmacyBillItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  billId String       @db.ObjectId
  bill   PharmacyBill @relation(fields: [billId], references: [id])

  medicineId String   @db.ObjectId
  medicine   Medicine @relation(fields: [medicineId], references: [id])

  quantity Int
  price    Float

  @@index([billId])
  @@index([medicineId])
}

model Medicine {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name    String
  company String
  price   Float
  stock   Int

  expiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billItems PharmacyBillItem[] // 🔥 IMPORTANT
}

///////////////////////////////
//Admission
//////////////////////////////
model Admission {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  doctorId  String  @db.ObjectId
  patientId String  @db.ObjectId
  nurseId   String? @db.ObjectId

  bedId String @db.ObjectId
  bed   Bed    @relation(fields: [bedId], references: [id])

  ward String

  reason    String?
  diagnosis String?

  admitDate     DateTime  @default(now())
  dischargeDate DateTime?
  status        String    @default("admitted")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nurse   Nurse?  @relation(fields: [nurseId], references: [id])

  // ✅ ADD THIS (IMPORTANT)
  bills Bill[]
}

///////////////////////////////
//BED
//////////////////////////////
model Bed {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  ward   String
  number String

  isOccupied Boolean @default(false)

  createdAt DateTime @default(now())

  // 🔥 ADD THIS
  admissions Admission[]
}

///////////////////////////////
//BILLING
//////////////////////////////
model Bill {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  patientId     String  @db.ObjectId
  appointmentId String? @db.ObjectId
  admissionId   String? @db.ObjectId

  type  String
  title String

  totalAmount Float
  paidAmount  Float @default(0)

  status      String  @default("pending")
  paymentMode String?

  createdAt DateTime @default(now())

  // ✅ RELATIONS ADD KAR
  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  admission   Admission?   @relation(fields: [admissionId], references: [id])
}

////////////////////////////////
//USer
///////////////////////////////
model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
  role     Role

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ MATCHED RELATIONS (IMPORTANT)
  admins        Admin[]        @relation("UserAdmins")
  doctors       Doctor[]       @relation("UserDoctors")
  patients      Patient[]      @relation("UserPatients")
  receptionists Receptionist[] @relation("UserReceptionists")
  nurses        Nurse[]        @relation("UserNurses")
}
